# ================================================================
# Variables d'environnement — copier dans .env pour le dev local
# À configurer dans le dashboard Vercel / Render pour la production
# ================================================================

# Base de données Supabase (obligatoire)
DATABASE_URL=postgresql://postgres:[MOT-DE-PASSE]@db.[REF].supabase.co:6543/postgres

# Identifiants admin (optionnel — défaut: admin / jmc2026)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=jmc2026

# Capacité max (optionnel — défaut: 100)
MAX_PLACES=100

# Nom de l'événement dans les logs (optionnel)
EVENT_NAME=JMC Soirée Cinéma 2026
